<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="480.0" prefHeight="320.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="war.controllers.GameSetupController"
            style="-fx-background-color: #1a5c2a;">

    <!-- TOP: Title -->
    <top>
        <VBox alignment="CENTER" style="-fx-background-color: #0f3d1a; -fx-padding: 16;">
            <Label text="Select Game Mode"
                   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
            <Label text="Select a game mode to begin"
                   style="-fx-text-fill: #aaaaaa; -fx-font-size: 12;"/>
        </VBox>
    </top>

    <!-- CENTER: Two-column layout -->
    <center>
        <HBox alignment="CENTER" spacing="0">
            <padding>
                <Insets top="20" bottom="20" left="20" right="20"/>
            </padding>

            <!-- LEFT: Round Mode -->
            <VBox alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS" prefWidth="200">
                <Label text="Round Mode"
                       style="-fx-text-fill: #88ccff; -fx-font-size: 14; -fx-font-weight: bold;"/>
                <Button fx:id="rounds20Button" text="20 Rounds"
                        prefWidth="160" prefHeight="42"
                        onAction="#handleRounds20"
                        style="-fx-font-size: 13; -fx-background-color: #1a6ca8; -fx-text-fill: white; -fx-background-radius: 6;"/>
                <Button fx:id="rounds50Button" text="50 Rounds"
                        prefWidth="160" prefHeight="42"
                        onAction="#handleRounds50"
                        style="-fx-font-size: 13; -fx-background-color: #1a6ca8; -fx-text-fill: white; -fx-background-radius: 6;"/>
                <Button fx:id="unlimitedButton" text="Unlimited"
                        prefWidth="160" prefHeight="42"
                        onAction="#handleUnlimited"
                        style="-fx-font-size: 13; -fx-background-color: #1a6ca8; -fx-text-fill: white; -fx-background-radius: 6;"/>
            </VBox>

            <!-- DIVIDER -->
            <Separator orientation="VERTICAL" style="-fx-padding: 0 10 0 10;"/>

            <!-- RIGHT: Time Attack Mode -->
            <VBox alignment="CENTER" spacing="12" HBox.hgrow="ALWAYS" prefWidth="200">
                <Label text="Time Attack"
                       style="-fx-text-fill: #ffaa44; -fx-font-size: 14; -fx-font-weight: bold;"/>
                <Button fx:id="time2Button" text="2 Minutes"
                        prefWidth="160" prefHeight="42"
                        onAction="#handleTime2"
                        style="-fx-font-size: 13; -fx-background-color: #a85c1a; -fx-text-fill: white; -fx-background-radius: 6;"/>
                <Button fx:id="time5Button" text="5 Minutes"
                        prefWidth="160" prefHeight="42"
                        onAction="#handleTime5"
                        style="-fx-font-size: 13; -fx-background-color: #a85c1a; -fx-text-fill: white; -fx-background-radius: 6;"/>
                <Button fx:id="time10Button" text="10 Minutes"
                        prefWidth="160" prefHeight="42"
                        onAction="#handleTime10"
                        style="-fx-font-size: 13; -fx-background-color: #a85c1a; -fx-text-fill: white; -fx-background-radius: 6;"/>
            </VBox>

        </HBox>
    </center>

</BorderPane>
